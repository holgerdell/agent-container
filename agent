def _shared_host_entry_host(entry: SharedHostPath) -> str | None:
    if isinstance(entry, str):
        return entry
    if isinstance(entry, dict):
        host = entry.get("host")
        return host if isinstance(host, str) else None
    return None


def _shared_host_entry_container(entry: SharedHostPath) -> str | None:
    if isinstance(entry, dict):
        container = entry.get("container")
        return container if isinstance(container, str) else None
    return None


def _color_for(stream: TextIO) -> bool:
    if os.environ.get("NO_COLOR"):
        return False
    if os.environ.get("FORCE_COLOR"):
        return True
    return stream.isatty()


_OUT_COLOR = _color_for(sys.stdout)
_ERR_COLOR = _color_for(sys.stderr)


def _sty(code: str, text: str, *, err: bool = False) -> str:
    enabled = _ERR_COLOR if err else _OUT_COLOR
    return f"\033[{code}m{text}\033[0m" if enabled else text


def _bold(s: str) -> str:
    return _sty("1", s)


_KEY_UP = "up"
_KEY_DOWN = "down"
_KEY_SPACE = "space"
_KEY_ENTER = "enter"
_KEY_CANCEL = "cancel"
_KEY_OTHER = "other"


def _tty_required() -> None:
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        die("setup requires an interactive terminal (stdin/stdout must be a TTY)")


@contextlib.contextmanager
def _raw_mode() -> Iterator[None]:
    fd = sys.stdin.fileno()
    saved = termios.tcgetattr(fd)
    sys.stdout.write("\x1b[?25l")
    sys.stdout.flush()
    try:
        tty.setcbreak(fd)
        mode = termios.tcgetattr(fd)
        mode[3] &= ~termios.ISIG
        termios.tcsetattr(fd, termios.TCSANOW, mode)
        yield
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, saved)
        sys.stdout.write("\x1b[?25h")
        sys.stdout.flush()


def _read_key() -> str:
    fd = sys.stdin.fileno()
    ch = os.read(fd, 1)
    if not ch or ch in (b"\x03", b"\x04"):
        return _KEY_CANCEL
    if ch in (b"\r", b"\n"):
        return _KEY_ENTER
    if ch == b" ":
        return _KEY_SPACE
    if ch in (b"k", b"K"):
        return _KEY_UP
    if ch in (b"j", b"J"):
        return _KEY_DOWN
    if ch == b"\x1b":
        ready, _, _ = select.select([fd], [], [], 0.05)
        if not ready or os.read(fd, 1) != b"[":
            return _KEY_OTHER
        ready, _, _ = select.select([fd], [], [], 0.05)
        if not ready:
            return _KEY_OTHER
        arrow = os.read(fd, 1)
        if arrow == b"A":
            return _KEY_UP
        if arrow == b"B":
            return _KEY_DOWN
    return _KEY_OTHER


_ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[A-Za-z]")


def _visible_width(s: str) -> int:
    return len(_ANSI_RE.sub("", s))


def _physical_rows(text: str) -> int:
    cols = shutil.get_terminal_size((80, 24)).columns
    rows = 0
    for line in text.split("\n")[:-1]:
        rows += max(1, (_visible_width(line) + cols - 1) // cols)
    return rows


def _erase(rows: int) -> None:
    if rows <= 0:
        return
    sys.stdout.write(f"\x1b[{rows}F\x1b[J")
    sys.stdout.flush()


def tui_select[T](
    message: str,
    choices: list[tuple[str, T, str]],
    *,
    initial: T | None = None,
    summary_message: str | None = None,
) -> T | None:
    _tty_required()
    if not choices:
        return None

    qmark = _sty("1;34", "?")
    pointer = _sty("1;34", "❯ ")

    idx = 0
    if initial is not None:
        for i, (_, value, _) in enumerate(choices):
            if value == initial:
                idx = i
                break
    rendered = 0
    final_message = summary_message or message

    def render(final_label: str | None = None) -> None:
        nonlocal rendered
        _erase(rendered)
        prompt = final_message if final_label is not None else message
        out = [f"{qmark} {_bold(prompt)}"]
        if final_label is None:
            out.append("\n")
            for i, (label, _, _) in enumerate(choices):
                if i == idx:
                    prefix = pointer
                    radio = _sty("34", "●")
                else:
                    prefix = "  "
                    radio = "○"
                out.append(f"{prefix}{radio} {label}\n")
            out.append("\n")
            for line in choices[idx][2].splitlines():
                out.append(f"  {_sty('2', line)}\n")
        else:
            out.append(f" {_sty('34', final_label)}\n")
        text = "".join(out)
        sys.stdout.write(text)
        sys.stdout.flush()
        rendered = _physical_rows(text)

    with _raw_mode():
        render()
        while True:
            key = _read_key()
            if key == _KEY_CANCEL:
                _erase(rendered)
                return None
            if key == _KEY_ENTER:
                label, value, _ = choices[idx]
                render(final_label=label)
                return value
            if key == _KEY_UP:
                idx = (idx - 1) % len(choices)
                render()
            elif key == _KEY_DOWN:
                idx = (idx + 1) % len(choices)
                render()


def tui_checkbox[T](
    message: str,
    choices: list[tuple[str, T, bool]],
    *,
    summary_message: str | None = None,
    details: str | None = None,
) -> list[T] | None:
    _tty_required()
    if not choices:
        return []

    qmark = _sty("1;34", "?")
    pointer = _sty("1;34", "❯ ")
    approve_label = "Submit selection"
    approve_idx = len(choices)

    idx = approve_idx
    checked = [c for _, _, c in choices]
    rendered = 0
    final_message = summary_message or message

    def render(final: bool = False) -> None:
        nonlocal rendered
        _erase(rendered)
        prompt = final_message if final else message
        out = [f"{qmark} {_bold(prompt)}"]
        if final:
            picked = [str(v) for (_, v, _), c in zip(choices, checked, strict=True) if c]
            answer = ", ".join(picked) if picked else "(none)"
            out.append(f" {_sty('34', answer)}\n")
        else:
            out.append("\n")
            if details is not None:
                for line in details.splitlines():
                    out.append(f"  {_sty('2', line)}\n")
                out.append("\n")
            for i, (label, _, _) in enumerate(choices):
                prefix = pointer if i == idx else "  "
                box = "[x]" if checked[i] else "[ ]"
                if checked[i]:
                    box = _sty("34", box)
                out.append(f"{prefix}{box} {label}\n")
            out.append("\n")
            if idx == approve_idx:
                out.append(f"{pointer}{_sty('1;32', approve_label)}\n")
            else:
                out.append(f"  {approve_label}\n")
        text = "".join(out)
        sys.stdout.write(text)
        sys.stdout.flush()
        rendered = _physical_rows(text)

    with _raw_mode():
        render()
        while True:
            key = _read_key()
            if key == _KEY_CANCEL:
                _erase(rendered)
                return None
            if key in (_KEY_ENTER, _KEY_SPACE):
                if idx == approve_idx:
                    render(final=True)
                    return [v for (_, v, _), c in zip(choices, checked, strict=True) if c]
                checked[idx] = not checked[idx]
                render()
            elif key == _KEY_UP:
                idx = (idx - 1) % (len(choices) + 1)
                render()
            elif key == _KEY_DOWN:
                idx = (idx + 1) % (len(choices) + 1)
                render()


