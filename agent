def _doctor_pass(label: str, value: str, width: int) -> None:
    mark = _sty("1;32", "●")
    print(f"  {mark}  {label.ljust(width)}  {_sty('2', value)}")


def _doctor_warn(label: str, value: str, width: int) -> None:
    mark = _sty("1;33", "●")
    print(f"  {mark}  {label.ljust(width)}  {value}")


def _doctor_block(text: str) -> None:
    bar = _sty("2", "│")
    for line in text.split("\n"):
        if line.startswith("#"):
            print(f"    {bar} {_sty('2', line)}")
        else:
            print(f"    {bar} {_sty('36', line)}")


def run_doctor(engine: str, image: str) -> None:
    print(_sty("1;34", "agent doctor"))
    print()

    label_w = 14
    _doctor_pass(engine, "running", label_w)

    warn_at = 1024
    recommended = 524288
    raw = _query_nofile_hard_limit(engine, image)
    if raw is None:
        _doctor_warn(
            "NOFILE limit",
            f"{_sty('2', 'skipped — run `agent build` first to check inside the real container')}",
            label_w,
        )
        print()
        return
    location = "agent container"
    if raw == "unlimited":
        _doctor_pass("NOFILE limit", f"unlimited  ·  {location}", label_w)
        print()
        return
    try:
        limit = int(raw)
    except ValueError:
        die(f"unexpected NOFILE value from {location}: {raw!r}")
    if limit > warn_at:
        _doctor_pass("NOFILE limit", f"{limit}  ·  {location}", label_w)
        print()
        return

    _doctor_warn(
        "NOFILE limit",
        f"{_sty('1;33', str(limit))}  ·  {location}  {_sty('2', f'(recommend {recommended})')}",
        label_w,
    )
    print()
    arrow = _sty("1;33", "→")
    print(f"  {arrow} {_bold('Why it matters')}")
    print(_sty("2", "    The 1024 hard cap is a systemd default, kept for select(2) safety."))
    print(_sty("2", "    Heavy parallel builds (e.g. `lake build`) blow past it."))
    print()
    if engine == "podman":
        where = "podman machine VM" if sys.platform == "darwin" else "host systemd config"
    else:
        where = "Docker Desktop settings" if sys.platform == "darwin" else "docker daemon.json"
    print(f"  {arrow} {_bold('Fix')} {_sty('2', f'— raise NOFILE in the {where}:')}")
    print()
    fix = _NOFILE_FIX[engine, sys.platform == "darwin"]
    _doctor_block(fix)
    if engine == "podman" and sys.platform == "darwin":
        print()
        print(_sty("2", "    Wiped if you `podman machine rm` and recreate the VM."))
    print()
    sys.exit(1)


def resolve_repo_root(pwd: Path, home: Path) -> Path:
    """Walk up from pwd for an ancestor containing `.git` (dir or file),
    bounded by home (exclusive). Return the first match, or pwd if none.
    `$HOME` itself is never returned even if it contains `.git` — otherwise
    a dotfiles-as-git-repo setup would mount the whole home directory."""
    p = pwd
    while p != home:
        if (p / ".git").exists():
            return p
        parent = p.parent
        if parent == p:
            break
        try:
            parent.relative_to(home)
        except ValueError:
            break
        p = parent
    return pwd


_ENGINE_INSTALL_HINT = {
    "podman": "https://podman.io/docs/installation",
    "docker": "https://docs.docker.com/get-docker/",
}


def check_engine(engine: str) -> None:
    if not shutil.which(engine):
        die(f"{engine} not in PATH\nInstall: {_ENGINE_INSTALL_HINT[engine]}")

    if engine == "podman" and sys.platform == "darwin":
        r = subprocess.run(
            ["podman", "machine", "list", "--format", "{{.Running}}"],
            capture_output=True,
            text=True,
            check=False,
        )
        running = any(line.strip() == "true" for line in r.stdout.splitlines())
        if not running:
            die("no running podman machine\nRemediation: podman machine start")

    r = _run_quiet([engine, "info"])
    if r.returncode != 0:
        stderr = r.stderr.decode(errors="replace").strip()
        die(f"`{engine} info` failed:\n{stderr}")


def image_exists(engine: str, image: str) -> bool:
    if engine == "podman":
        cmd = ["podman", "image", "exists", image]
    else:
        cmd = ["docker", "image", "inspect", image]
    return _run_quiet(cmd).returncode == 0


def runtime_nix_volume_name(image_id: str) -> str:
    # Keyed by image content so each build gets its own /nix volume.
    # Lets concurrent agents on different builds keep working — old container
    # holds its image+volume, new run gets a fresh pair. Stale volumes from
    # prior builds accumulate until `agent clean`.
    short = image_id.removeprefix("sha256:")[:12]
    if not short:
        die(f"unexpected empty image id: {image_id!r}")
    return f"{RUNTIME_NIX_VOLUME_PREFIX}{short}"


def inspect_image_id(engine: str, image: str) -> str:
    r = subprocess.run(
        [engine, "inspect", "--format", "{{.Id}}", image],
        capture_output=True,
        text=True,
        check=False,
    )
    if r.returncode != 0:
        die(f"could not inspect {image}:\n{r.stderr.strip() or f'exit {r.returncode}'}")
    return r.stdout.strip()


def build_container_name(uid: int, gid: int) -> str:
    return f"agent-build-u{uid}g{gid}"


def _is_container_running(engine: str, name: str) -> bool:
    r = subprocess.run(
        [engine, "ps", "--filter", f"name={name}", "--format", "{{.Names}}"],
        capture_output=True,
        text=True,
        check=False,
    )
    return any(line.strip() == name for line in r.stdout.splitlines())


def _run_quiet(cmd: list[str]) -> subprocess.CompletedProcess[bytes]:
    return subprocess.run(cmd, capture_output=True, check=False)


def _clean_step(label: str, cmd: list[str], *, missing_ok: bool = False) -> None:
    print(f"{_sty('1;34', '→')} {label}...")
    r = _run_quiet(cmd)
    stderr = r.stderr.decode(errors="replace").strip()
    if r.returncode == 0:
        print(f"{_sty('1;32', '✓')} {label}.")
        return
    if missing_ok:
        missing_markers = (
            "No such image",
            "No such object",
            "No such volume",
            "not found",
        )
        if any(marker in stderr for marker in missing_markers):
            print(f"{_sty('2', '•')} {label}: already absent.")
            return
    warn(f"{label} failed: {stderr or f'exit {r.returncode}'}")


def _resources_in_use(engine: str) -> tuple[set[str], set[str]]:
    """Return (short_image_ids, volume_names) currently in use by running containers."""
    r = subprocess.run(
        [engine, "ps", "-aq", "--no-trunc"],
        capture_output=True,
        text=True,
        check=False,
    )
    if r.returncode != 0 or not r.stdout.strip():
        return set(), set()
    container_ids = [c.strip() for c in r.stdout.splitlines() if c.strip()]
    ri = subprocess.run(
        [engine, "inspect", "--format", "{{.Image}}", *container_ids],
        capture_output=True,
        text=True,
        check=False,
    )
    image_ids: set[str] = set()
    if ri.returncode == 0:
        for raw in ri.stdout.splitlines():
            raw = raw.strip()
            if raw:
                image_ids.add(raw.removeprefix("sha256:")[:12])
    rv = subprocess.run(
        [engine, "inspect", "--format", "{{range .Mounts}}{{if .Name}}{{.Name}}\n{{end}}{{end}}", *container_ids],
        capture_output=True,
        text=True,
        check=False,
    )
    vol_names: set[str] = set()
    if rv.returncode == 0:
        for raw in rv.stdout.splitlines():
            raw = raw.strip()
            if raw:
                vol_names.add(raw)
    return image_ids, vol_names


def run_clean(engine: str) -> None:
    in_use_ids, in_use_vols = _resources_in_use(engine)

    print(f"{_sty('1;34', '→')} Inspecting agent images...")
    r = subprocess.run(
        [engine, "images", "--format", "{{.Repository}}:{{.Tag}}\t{{.ID}}", "agent"],
        capture_output=True,
        text=True,
        check=False,
    )
    if r.returncode != 0:
        die(f"could not list agent images:\n{r.stderr.strip() or f'exit {r.returncode}'}")

    tag_rows: list[tuple[str, str]] = []
    for line in r.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        parts = line.split("\t", 1)
        if len(parts) == 2:
            tag_rows.append((parts[0], parts[1]))
    skipped_tags = [tag for tag, img_id in tag_rows if img_id[:12] in in_use_ids]
    tags = [tag for tag, img_id in tag_rows if img_id[:12] not in in_use_ids]
    if skipped_tags:
        print(f"{_sty('2', '•')} Skipping in-use images: {', '.join(skipped_tags)}")
    if tags:
        print(f"{_sty('2', '•')} Found images: {', '.join(tags)}")
        _clean_step("Removing agent images", [engine, "rmi", *tags], missing_ok=True)
    else:
        print(f"{_sty('2', '•')} Removing agent images: nothing to do.")

    print(f"{_sty('1;34', '→')} Inspecting runtime nix volumes...")
    r = subprocess.run(
        [engine, "volume", "ls", "--filter", f"name={RUNTIME_NIX_VOLUME_PREFIX}", "--format", "{{.Name}}"],
        capture_output=True,
        text=True,
        check=False,
    )
    all_vols = [v.strip() for v in r.stdout.splitlines() if v.strip()]
    skipped_vols = [v for v in all_vols if v in in_use_vols]
    vols = [v for v in all_vols if v not in in_use_vols]
    if skipped_vols:
        print(f"{_sty('2', '•')} Skipping in-use volumes: {', '.join(skipped_vols)}")
    if vols:
        print(f"{_sty('2', '•')} Found runtime volumes: {', '.join(vols)}")
        _clean_step(
            f"Removing {len(vols)} runtime nix volume(s)",
            [engine, "volume", "rm", *vols],
            missing_ok=True,
        )
    else:
        print(f"{_sty('2', '•')} Removing runtime nix volumes: nothing to do.")
    print(f"{_sty('1;32', '✓')} Clean finished.")


def build(engine: str, image: str) -> None:
    uid, gid = os.getuid(), os.getgid()
    build_name = build_container_name(uid, gid)
    if _is_container_running(engine, build_name):
        print(f"{_sty('1;34', '→')} Another build is already running ({build_name}); waiting for it to finish...")
        r = subprocess.run([engine, "wait", build_name], capture_output=True, text=True, check=False)
        if r.returncode != 0:
            die(f"failed to wait for concurrent build {build_name}:\n{r.stderr.strip() or f'exit {r.returncode}'}")
        # `engine wait` prints the container's exit code(s) on stdout.
        failed = [code for code in r.stdout.strip().splitlines() if code and code != "0"]
        if failed:
            die(f"concurrent build {build_name} exited with status {failed[0]!r}; rerun `agent build`")
        # Peer's `engine load`/`engine tag` may still be in flight after the
        # container exits; if the image isn't yet visible, ask the user to retry.
        if not image_exists(engine, image):
            die(f"concurrent build {build_name} finished but image {image} is not yet tagged; rerun shortly")
        return
    # Clear any stopped leftover (e.g. from a crash) so `--name` can claim it.
    _run_quiet([engine, "rm", build_name])
    _run_quiet([engine, "volume", "create", NIX_BUILD_CACHE_VOLUME])
    print(f"{_sty('1;34', '→')} Building...")
    build_proc = subprocess.Popen(
        [
            engine,
            "run",
            "--rm",
            "--name",
            build_name,
            "-v",
            f"{NIX_BUILD_CACHE_VOLUME}:/nix",
            "-v",
            f"{SCRIPT_DIR / 'agent-image'}:/build:ro,z",
            "-e",
            f"AGENT_UID={uid}",
            "-e",
            f"AGENT_GID={gid}",
            NIX_IMAGE,
            "sh",
            "-c",
            'cat "$(nix build path:/build#image --no-link --print-out-paths'
            " --impure --extra-experimental-features 'nix-command flakes')\"",
        ],
        stdout=subprocess.PIPE,
    )
    assert build_proc.stdout is not None
    print(f"{_sty('1;34', '→')} Loading...")
    load = subprocess.run(
        [engine, "load"],
        stdin=build_proc.stdout,
        capture_output=True,
        text=True,
        check=False,
    )
    build_proc.stdout.close()
    build_rc = build_proc.wait()
    if build_rc != 0:
        die(f"nix build failed (exit {build_rc})")
    if load.returncode != 0:
        die(f"{engine} load failed:\n{load.stderr}")
    # podman prefixes loaded images with `localhost/`; docker does not.
    m = re.search(r"(?:localhost/)?agent:[a-z0-9]+", load.stdout)
    if m is None:
        die(f"could not extract image tag from `{engine} load` output:\n{load.stdout.strip() or '(empty)'}")
    subprocess.run([engine, "tag", m.group(0), image], check=True)
    print(f"{_sty('1;32', '✓')} Tagged {m.group(0)} as {image}")
    # No volume removal: runtime volume name is derived from image ID at
    # `agent run`, so the new image gets its own fresh volume on first use.
    # Any agent still running against the previous image keeps its volume.


def run_update(engine: str) -> None:
    _run_quiet([engine, "volume", "create", NIX_BUILD_CACHE_VOLUME])
    print(f"{_sty('1;34', '→')} Updating flake.lock...")
    subprocess.run(
        [
            engine,
            "run",
            "--rm",
            "-v",
            f"{NIX_BUILD_CACHE_VOLUME}:/nix",
            "-v",
            f"{SCRIPT_DIR / 'agent-image'}:/build",
            NIX_IMAGE,
            "sh",
            "-c",
            "cd /build && nix flake update --extra-experimental-features 'nix-command flakes'",
        ],
        check=True,
    )
    print(f"{_sty('1;32', '✓')} flake.lock updated.")
    r = subprocess.run(
        ["git", "-C", str(SCRIPT_DIR), "diff", "--quiet", "HEAD", "--", "agent-image/flake.lock"],
        check=False,
    )
    if r.returncode == 0:
        print(_sty("2", "  flake.lock unchanged — nothing to commit."))
        return
    subprocess.run(["git", "-C", str(SCRIPT_DIR), "add", "agent-image/flake.lock"], check=True)
    subprocess.run(
        ["git", "-C", str(SCRIPT_DIR), "commit", "-m", "Update flake.lock"],
        check=True,
    )
    print(f"{_sty('1;32', '✓')} Committed.")


def parse_args(argv: list[str]) -> tuple[str, list[str]]:
    if not argv:
        return "run", []
    if argv[0] == "--":
        return "run", argv[1:]
    if argv[0] in SUBCOMMANDS:
        rest = argv[1:]
        if rest and rest[0] == "--":
            rest = rest[1:]
        return argv[0], rest
    die(f"unknown subcommand: {argv[0]!r} (run `agent help`)")


def main() -> None:
    cmd, extra = parse_args(sys.argv[1:])

    if cmd == "help":
        print(HELP_TEXT, end="")
        return

    if cmd == "setup":
        run_setup()
        return

    if not settings_path().exists():
        run_setup()
    settings = load_settings()
    engine = settings["container_engine"]

    # Image is UID-keyed because the agent user inside it is baked at build time.
    image = os.environ.get("AGENT_IMAGE", f"agent:u{os.getuid()}g{os.getgid()}")

    check_engine(engine)

    if cmd == "doctor":
        run_doctor(engine, image)
        return

    if cmd == "clean":
        run_clean(engine)
        return

    if cmd == "update":
        run_update(engine)
        return

    if cmd == "check":
        subprocess.run(
            [
                engine,
                "run",
                "--rm",
                "-v",
                f"{SCRIPT_DIR / 'agent-image'}:/build:ro,z",
                NIX_IMAGE,
                "nix",
                "flake",
                "check",
                "path:/build",
                "--impure",
                "--extra-experimental-features",
                "nix-command flakes",
            ],
            stdout=subprocess.DEVNULL,
            check=True,
        )
        return

    if cmd == "build":
        build(engine, image)
        return

    if not image_exists(engine, image):
        build(engine, image)

    cwd = Path.cwd().resolve()
    if settings["mount_mode"] == "repo_root":
        mount_root = resolve_repo_root(cwd, Path.home().resolve())
    else:
        mount_root = cwd

    xdg_data = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share"))
    data_dir = xdg_data / "agent-container"
    home_dir = data_dir / "home"
    first_run = not data_dir.exists()
    home_dir.mkdir(parents=True, exist_ok=True)
    if first_run:
        (data_dir / "README").write_text(
            "This directory is managed by agent-container.\n"
            "It persists the home directory of the in-container agent across runs.\n"
            "It also persists the in-container /nix store across runs via a container volume.\n"
            "\n"
            "  home/   bind-mounted as /home/agent/ inside the container\n"
        )

    # `:z` relabels bind mounts with a shared SELinux context so the container
    # can access them on SELinux-enforced hosts (Fedora, RHEL). The relabel is
    # destructive — it `chcon`s the host paths in place — so apply only to the
    # dedicated container home dir, never to user files (workspace, dotfiles,
    # credential cache). Containers there get a relabel via the host-side
    # `container_file_t` rule on $XDG_DATA_HOME, or the user can chcon
    # manually.
    uid, gid = os.getuid(), os.getgid()
    runtime_nix_volume = runtime_nix_volume_name(inspect_image_id(engine, image))
    # Do NOT pre-create the volume here. Docker only seeds a named volume from
    # image content when Docker itself creates it during `docker run`. If the
    # volume already exists (even empty), Docker skips seeding and mounts an
    # empty /nix, making all Nix-store executables unreachable.

    mount_specs = [
        f"{mount_root}:{mount_root}",
        f"{home_dir}:/home/agent:z",
    ]
    if Path("/etc/localtime").is_file():
        mount_specs.append("/etc/localtime:/etc/localtime:ro")
    cred_cache = Path.home() / ".cache/git/credential"
    if cred_cache.is_dir():
        mount_specs.append(f"{cred_cache}:/home/agent/.cache/git/credential")
    allowlist_container = {host: container for host, container, _ in SHARED_HOST_PATHS_ALLOWLIST}
    for entry in settings["shared_host_paths"]:
        if isinstance(entry, dict):
            host_pattern = _shared_host_entry_host(entry)
            container_path = _shared_host_entry_container(entry)
            if host_pattern is None or container_path is None:
                continue
        elif isinstance(entry, str):
            host_pattern = entry
            container_path = allowlist_container.get(entry)
            if container_path is None:
                continue
        else:
            continue
        host_path = Path(host_pattern).expanduser()
        if not host_path.exists():
            continue
        mount_specs.append(f"{host_path}:{container_path}:ro")
    mount_flags = [arg for m in mount_specs for arg in ("-v", m)]

    base = [engine, "run", "--rm", "-it", "--user", f"{uid}:{gid}"]
    if engine == "podman":
        # Rootless podman: map host UID to itself inside the user namespace.
        # Docker has no equivalent — rootless docker already runs as the host
        # uid, and rootful docker maps `--user` directly without a userns, so
        # don't add `--userns=keep-id` for docker.
        base.append("--userns=keep-id")
    base += [
        "--memory-swap=-1",
        "--ulimit", "nofile=524288:524288",
        "-v",
        f"{runtime_nix_volume}:/nix",
        *mount_flags,
        "-w",
        str(cwd),
    ]

    # SSH agent forwarding — key never enters the container.
    # macOS + Docker Desktop: socket injected by Docker Desktop at a fixed path.
    # Linux: forward the host socket via bind-mount.
    if sys.platform == "darwin" and engine == "docker":
        base += ["-e", "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock"]
    elif sys.platform != "darwin":
        _ssh_sock = os.environ.get("SSH_AUTH_SOCK", "")
        if _ssh_sock and Path(_ssh_sock).is_socket():
            base += ["-v", f"{_ssh_sock}:{_ssh_sock}", "-e", f"SSH_AUTH_SOCK={_ssh_sock}"]

    if cmd == "shell":
        tail = ["--entrypoint", "bash", image, *extra]
    else:
        tail = [image, "claude", "--dangerously-skip-permissions", *extra]

    os.execvp(engine, [*base, *tail])


if __name__ == "__main__":
    main()
