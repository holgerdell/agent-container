def die(msg: str) -> NoReturn:
    label = _sty("1;31", "error", err=True)
    print(f"agent: {label}: {msg}", file=sys.stderr)
    raise SystemExit(1)


def warn(msg: str) -> None:
    label = _sty("1;33", "warning", err=True)
    print(f"agent: {label}: {msg}", file=sys.stderr)


def settings_path() -> Path:
    xdg = os.environ.get("XDG_CONFIG_HOME")
    base = Path(xdg) if xdg else Path.home() / ".config"
    return base / "agent-container" / "settings.json"


def load_settings() -> dict[str, Any]:
    path = settings_path()
    try:
        raw = path.read_text()
    except FileNotFoundError:
        return dict(DEFAULT_SETTINGS)
    try:
        loaded = json.loads(raw)
    except json.JSONDecodeError as e:
        die(f"malformed settings file {path}: {e}\nRun `agent setup` to recreate it.")
    if not isinstance(loaded, dict):
        die(f"malformed settings file {path}: expected JSON object\nRun `agent setup` to recreate it.")
    result = dict(DEFAULT_SETTINGS)
    for key, value in loaded.items():
        if key in DEFAULT_SETTINGS:
            result[key] = value
        else:
            warn(f"ignoring unknown setting {key!r} in {path}")
    if result["container_engine"] not in CONTAINER_ENGINES:
        warn(f"unknown container_engine {result['container_engine']!r} in {path}; using {DEFAULT_SETTINGS['container_engine']!r}")
        result["container_engine"] = DEFAULT_SETTINGS["container_engine"]
    valid_modes = {"pwd", "repo_root"}
    if result["mount_mode"] not in valid_modes:
        warn(f"unknown mount_mode {result['mount_mode']!r} in {path}; using {DEFAULT_SETTINGS['mount_mode']!r}")
        result["mount_mode"] = DEFAULT_SETTINGS["mount_mode"]
    raw_shared = result["shared_host_paths"]
    if not isinstance(raw_shared, list):
        warn(f"shared_host_paths in {path} is not a list; ignoring")
        result["shared_host_paths"] = []
    else:
        allowlisted = {host for host, _, _ in SHARED_HOST_PATHS_ALLOWLIST}
        filtered: list[SharedHostPath] = []
        for entry in raw_shared:
            if isinstance(entry, str):
                if entry in allowlisted:
                    filtered.append(entry)
                    continue
                warn(
                    f"dropping shared_host_paths entry {entry!r} from {path}: "
                    f"unknown host with no container mapping; use {{host: ..., container: ...}} form for custom mounts"
                )
                continue
            if isinstance(entry, dict):
                host = _shared_host_entry_host(entry)
                container = _shared_host_entry_container(entry)
                if host and container:
                    filtered.append({"host": host, "container": container})
                    continue
            warn(f"ignoring malformed shared_host_paths entry {entry!r} in {path}")
        result["shared_host_paths"] = filtered
    return result


def save_settings(values: dict[str, Any]) -> None:
    path = settings_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(dir=path.parent, prefix=".settings.", suffix=".tmp")
    tmp = Path(tmp_name)
    try:
        with os.fdopen(fd, "w") as f:
            json.dump(values, f, indent=2, sort_keys=True)
            f.write("\n")
        tmp.chmod(0o644)
        tmp.replace(path)
    except BaseException:
        tmp.unlink(missing_ok=True)
        raise


def _detect_engine() -> str:
    for candidate in CONTAINER_ENGINES:
        if shutil.which(candidate):
            return candidate
    return CONTAINER_ENGINES[0]


def _ask_questions(current: dict[str, Any]) -> dict[str, Any] | None:
    result = dict(current)

    default_marker = _sty("34", "(default)")

    default_engine = DEFAULT_SETTINGS["container_engine"]
    engine_choices: list[tuple[str, str, str]] = []
    for value in CONTAINER_ENGINES:
        label = value
        if value == default_engine:
            label = f"{label} {default_marker}"
        if value == "docker":
            description = "Most common setup; usually works without extra tuning.\nBest default for compatibility across machines and docs."
        else:
            description = "Daemonless engine with strong rootless workflows.\nUseful if you already use Podman, but less universal."
        engine_choices.append((label, value, description))
    engine_initial = current.get("container_engine") or _detect_engine()
    engine = tui_select(
        "Which container engine should agent use to run your workspace?",
        engine_choices,
        initial=engine_initial,
        summary_message="Container engine",
    )
    if engine is None:
        return None
    result["container_engine"] = engine

    default_mount = DEFAULT_SETTINGS["mount_mode"]
    mount_choices: list[tuple[str, str, str]] = []
    for label, value in [
        ("repository root (walk up to .git)", "repo_root"),
        ("current directory only", "pwd"),
    ]:
        if value == default_mount:
            label = f"{label} {default_marker}"
        if value == "pwd":
            description = (
                "Share only this directory from the host with the container.\n"
                "Keeps access narrow, but sibling packages stay outside the workspace."
            )
        else:
            description = (
                "Walk up to .git and share the whole repository root from the host.\n"
                "Best for multi-package work, but exposes more project files."
            )
        mount_choices.append((label, value, description))

    mount_mode = tui_select(
        "How should agent choose which workspace directory to mount?",
        mount_choices,
        initial=current["mount_mode"],
        summary_message="Workspace mount",
    )
    if mount_mode is None:
        return None
    result["mount_mode"] = mount_mode

    current_shared = current.get("shared_host_paths", [])
    selected_builtin_hosts = {entry for entry in current_shared if isinstance(entry, str)}
    allowlisted = [
        (host, desc) for host, _, desc in SHARED_HOST_PATHS_ALLOWLIST if Path(host).expanduser().exists() or host in selected_builtin_hosts
    ]
    custom_entries: list[tuple[str, SharedHostPath]] = []
    for entry in current_shared:
        if not isinstance(entry, dict):
            continue
        host = _shared_host_entry_host(entry)
        container = _shared_host_entry_container(entry)
        if host is None or container is None:
            continue
        label = f"{host} -> {container}  custom read-only mount"
        custom_entries.append((label, {"host": host, "container": container}))
    available = [(f"{host}  {desc}", host, host in selected_builtin_hosts) for host, desc in allowlisted] + [
        (label, value, True) for label, value in custom_entries
    ]
    if available:
        shared = tui_checkbox(
            "Which extra host paths should be mounted read-only into the container?",
            available,
            summary_message="Read-only host mounts",
            details=(
                "These mounts add host files or directories at fixed paths inside the container.\n"
                "Useful for config and auth, but each mount exposes more host state.\n"
                "Add custom entries by editing settings.json and re-running `agent setup`."
            ),
        )
        if shared is None:
            return None
        result["shared_host_paths"] = shared
    else:
        result["shared_host_paths"] = []

    return result


def run_setup() -> None:
    _tty_required()
    path = settings_path()
    current = load_settings() if path.exists() else dict(DEFAULT_SETTINGS)

    print(_sty("2", f"Setup writes to {path}"))
    print()

    try:
        updated = _ask_questions(current)
    except (KeyboardInterrupt, EOFError):
        sys.exit(1)
    if updated is None:
        sys.exit(1)
    save_settings(updated)

    print()
    print(f"{_sty('1;32', '✓')} Saved.")


def _query_nofile_hard_limit(engine: str, image: str) -> str | None:
    """Run `ulimit -Hn` inside the agent container.
    Returns a decimal string, 'unlimited', or None if the image isn't built."""
    if not image_exists(engine, image):
        return None
    r = subprocess.run(
        [engine, "run", "--rm", image, "sh", "-c", "ulimit -Hn"],
        capture_output=True,
        text=True,
        check=False,
    )
    if r.returncode != 0:
        die(f"could not query NOFILE limit in agent container:\n{r.stderr.strip() or 'unknown error'}")
    return r.stdout.strip()


